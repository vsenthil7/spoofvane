# DoppelDomain — example .env
#
# Copy this file to .env at the repo root and edit values.
# In MOCK_MODE=true (the default), no real keys are needed — the
# system runs end-to-end against fixture data.

# ─── Run mode ──────────────────────────────────────────────────────────
MOCK_MODE=true
LOG_LEVEL=INFO
ENVIRONMENT=dev

# ─── Storage ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/doppeldomain.db
EVIDENCE_DIR=data/evidence
REPORTS_DIR=data/reports

# ─── Anthropic ─────────────────────────────────────────────────────────
# Set ANTHROPIC_API_KEY when you want real Claude verdicts.
# Leave blank in MOCK_MODE.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Bright Data ───────────────────────────────────────────────────────
# Required when MOCK_MODE=false.
BRIGHTDATA_API_KEY=
BRIGHTDATA_CDP_ENDPOINT=wss://brd.superproxy.io:9222
BRIGHTDATA_PROXY_HOST=brd.superproxy.io
BRIGHTDATA_PROXY_PORT=22225
BRIGHTDATA_PROXY_USER=
BRIGHTDATA_PROXY_PASS=
BRIGHTDATA_SERP_HOST=brd.superproxy.io:33335
BRIGHTDATA_UNLOCKER_ZONE=unlocker

# ─── Webhooks (optional) ───────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
SENTINEL_WORKSPACE_ID=
SENTINEL_SHARED_KEY=

# ─── Scoring thresholds (per-brand override in DB) ─────────────────────
SCORE_THRESHOLD_COMPOSITE=0.65
SCORE_WEIGHT_PHASH=0.35
SCORE_WEIGHT_DOM=0.25
SCORE_WEIGHT_LOGO=0.30
SCORE_WEIGHT_FAVICON=0.10

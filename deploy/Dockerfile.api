# SpoofVane API — production image (FastAPI + uvicorn over the real backend).
# CPU-only; all inference is via the Anthropic/OpenAI/Bright Data APIs.
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUTF8=1

WORKDIR /app

RUN apt-get update -y \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# Python deps first (layer cache). uvicorn + anthropic + openai are pinned in
# requirements.txt.
COPY requirements.txt ./
RUN pip install --upgrade pip \
    && pip install -r requirements.txt

# App source.
COPY src ./src
COPY scripts ./scripts
COPY data ./data

# Non-root runtime user. Also create the /data mountpoint owned by that user so
# that a FRESH named volume inherits uid 10001 ownership (Docker copies the
# image mountpoint's perms into a new empty volume) and the app can create
# /data/evidence, /data/reports, etc. at startup.
RUN useradd -m -u 10001 spoofvane \
    && mkdir -p /data/evidence /data/reports /data/canonical \
    && chown -R spoofvane:spoofvane /app /data
USER spoofvane

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=5 \
    CMD curl -fsS http://localhost:8000/healthz || exit 1

# uvicorn serves the FastAPI app (src/api/app.py:app).
CMD ["uvicorn", "src.api.app:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]

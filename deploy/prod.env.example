# SpoofVane — production env template. Copied to .env by deploy/02-deploy.sh.
# Secrets (API keys, SECRET_KEY) are filled either by the deploy script from the
# invoking environment, or hand-edited on the server. NEVER commit a filled .env.

# ---- Run mode ----
# Production demo: live ensemble + live Bright Data. Set MOCK_MODE=true to force
# the offline rule-based path (no LLM spend).
MOCK_MODE=false
SPOOFVANE_BD_MODE=live
ENVIRONMENT=prod
LOG_LEVEL=INFO

# ---- LLM verdict providers (fill on the server or pass to 02-deploy.sh) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro-latest

# ---- SPONSOR: Bright Data ----
BRIGHTDATA_API_KEY=
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_CUSTOMER_ID=
BRIGHTDATA_ZONE_SERP=spoofvane_serp
BRIGHTDATA_ZONE_UNLOCKER=spoofvane_unlocker
BRIGHTDATA_ZONE_RESIDENTIAL=spoofvane_res
BRIGHTDATA_ZONE_SB=spoofvane_sb
BRIGHTDATA_MONTHLY_USD=250

# ---- Secret (auto-generated by 02-deploy.sh if left as the placeholder) ----
SECRET_KEY=__SECRET_KEY__

# ---- Deepfake ONNX (optional; 0 = use the scorer's deterministic path) ----
SPOOFVANE_DEEPFAKE_ONNX=0

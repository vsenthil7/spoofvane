# SpoofVane — Environment Variables Example
#
# Copy to .env in the repo root and fill in real values. .env is gitignored;
# NEVER commit it. Pattern mirrors the sibling projects (Verixa/Forensa/ATRIO)
# per claude-memory CLAUDE_RULES env-var convention, so one dev .env can back
# several repos.
#
# Setup:
#   1. Copy-Item .env.example .env       (PowerShell)
#   2. Replace each your_*_here / blank value with a real value.
#   3. Restart your shell so new env vars are picked up.
#
# THE WHOLE APP RUNS WITH NO KEYS in replay/mock mode. Every blank key falls
# back to a deterministic, input-dependent replay lane (no network). Keys are
# only needed to flip a given surface to its LIVE path; until then each live
# path is marked 🔒 BLOCKED-ENV in docs/TRACEABILITY_MASTER.md.

# ============================================================================
# Run mode
# ============================================================================
MOCK_MODE=true                # true = deterministic mock lane, no network
SPOOFVANE_BD_MODE=replay      # replay | live | mock  (Bright Data + ensemble lane)
ENVIRONMENT=dev               # dev | staging | prod
LOG_LEVEL=INFO

# ============================================================================
# SPONSOR — Bright Data (the AT-Hack0023 sponsor; all 7 products)
# ----------------------------------------------------------------------------
# Step 1: Create a Bright Data account → https://brightdata.com
# Step 2: Create zones for each product you want LIVE and copy the zone
#         password from the zone's "Access parameters" tab.
# Step 3: Account settings → API tokens → generate → BRIGHTDATA_API_KEY.
# Step 4: Set SPOOFVANE_BD_MODE=live to exercise live paths (else replay).
# The 7 products: SERP, Web Unlocker, Scraping Browser, Residential proxy,
# Web Scraper, Datasets, Bright Data MCP — all wired in src/integrations/brightdata/.
# ============================================================================
BRIGHTDATA_API_KEY=your_brightdata_api_token_here
BRIGHTDATA_CDP_ENDPOINT=wss://brd.superproxy.io:9222
BRIGHTDATA_PROXY_HOST=brd.superproxy.io
BRIGHTDATA_PROXY_PORT=22225
BRIGHTDATA_PROXY_USER=your_zone_username_here     # e.g. brd-customer-<id>-zone-<zone>
BRIGHTDATA_PROXY_PASS=your_zone_password_here
BRIGHTDATA_SERP_HOST=brd.superproxy.io:33335
BRIGHTDATA_UNLOCKER_ZONE=unlocker
BRIGHTDATA_MONTHLY_USD=500.0   # spend envelope; kill-switch throttles at 80%

# ============================================================================
# LLM verdict providers (verdict ensemble: Claude primary + GPT + Gemini)
# ----------------------------------------------------------------------------
# Anthropic (primary verdict): https://console.anthropic.com → API Keys
# OpenAI   (ensemble diversity): https://platform.openai.com/api-keys
# Gemini   (ensemble diversity): https://aistudio.google.com/app/apikey
# Blank => that model stays on the deterministic replay lane (still ensembles,
# just no live network). Disagreement-surfacing (D4) works in replay too.
# ============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro-latest

# ============================================================================
# Deepfake ONNX (v07 W10/D1) — model weights, not a key
# ----------------------------------------------------------------------------
# Drop ONNX detector weights under data/models/ and flip the flag to 1.
# Without weights the ONNX path is feature-flagged off (🔒 BLOCKED-ENV).
# ============================================================================
SPOOFVANE_DEEPFAKE_ONNX=0

# ============================================================================
# Storage / identity / secret
# ============================================================================
DATABASE_URL=sqlite:///./data/spoofvane.db
SECRET_KEY=change_me_in_production_min_32_chars_0123456789

# ============================================================================
# Delivery channels (all optional; blank => logged, not sent)
# SOAR/SIEM: Splunk HEC, MS Sentinel, ServiceNow, PagerDuty, TAXII, webhooks
# ============================================================================
SLACK_WEBHOOK_URL=
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
SENTINEL_WORKSPACE_ID=
SENTINEL_SHARED_KEY=
SERVICENOW_INSTANCE=
SERVICENOW_USER=
SERVICENOW_PASS=
PAGERDUTY_ROUTING_KEY=
TAXII_COLLECTION_URL=
TAXII_USERNAME=
TAXII_PASSWORD=
WEBHOOK_SIGNING_SECRET=
GENERIC_WEBHOOK_URL=

# ============================================================================
# Takedown automation (v06 §D / v07 W6) — all live submissions BLOCKED-ENV
# ============================================================================
CLOUDFLARE_ABUSE_EMAIL=
CLOUDFLARE_API_TOKEN=
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
GODADDY_API_KEY=
GODADDY_API_SECRET=

# ============================================================================
# SSO / OIDC (optional — Okta, Entra ID, Auth0, Google Workspace)
# ============================================================================
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ============================================================================
# Email / SMTP (optional — blank => emails logged, not sent)
# ============================================================================
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
